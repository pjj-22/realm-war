DATABASE_URL=postgresql://postgres:password@localhost:5432/realmwar
# Generate real secrets with: openssl rand -base64 32
# (production refuses to boot with placeholders)
JWT_SECRET=change_this_to_a_random_secret
ADMIN_SECRET=change_this_to_a_random_secret
PORT=3001

# ─── Production only ───────────────────────────────────────────────────────────
# NODE_ENV=production          # enables boot-time config checks
# DEV_MODE=false               # REQUIRED in prod - defaults to dev balance otherwise
# CLIENT_ORIGIN=https://yourdomain.com   # comma-separated allowed CORS origins
# TRUST_PROXY=1                # hops to trust when behind nginx/Cloudflare (rate-limit keying)

# Web push - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
